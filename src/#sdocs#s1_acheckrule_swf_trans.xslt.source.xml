<xsl:transform xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:sap="http://www.sap.com/sapxsl" version="1.0">
  <xsl:output encoding="iso-8859-1" method="xml" version="1.0"/>
  <xsl:strip-space elements="*"/>
  <xsl:template match="/">
    <asx:abap xmlns:asx="http://www.sap.com/abapxml" version="1.0">
      <asx:values>
        <RESULT>
          <xsl:apply-templates select="//RESULT"/>
        </RESULT>
        <STAGES>
          <xsl:apply-templates select="//RESULT/ALL_STAGES/STAGES"/>
        </STAGES>
        <BUSINESS_RULES>
          <xsl:apply-templates select="//RESULT/ALL_STAGES/STAGES/BUSINESS_RULES/BUSINESS_RULE"/>
        </BUSINESS_RULES>
         </asx:values>
    </asx:abap>
  </xsl:template>


 <xsl:template match="RESULT">
    <item>
      <STATUS>
        <xsl:value-of select="STATUS"/>
      </STATUS>
      <MESSAGE>
        <xsl:value-of select="MESSAGE"/>
      </MESSAGE>
    </item>
  </xsl:template>

  <xsl:template match="RESULT/ALL_STAGES/STAGES">
    <item>
      <STAGE_NAME>
        <xsl:value-of select="STAGE_NAME"/>
      </STAGE_NAME>
      <STAGE_TYPE>
        <xsl:value-of select="STAGE_TYPE"/>
      </STAGE_TYPE>
      <AGENT_ID>
        <xsl:value-of select="AGENT_ID"/>
      </AGENT_ID>
      <CANEDIT>
        <xsl:value-of select="CANEDIT"/>
      </CANEDIT>
      <STAGE_CLEARED>
        <xsl:value-of select="STAGE_CLEARED"/>
      </STAGE_CLEARED>
      <CONDITIONAL>
        <xsl:value-of select="CONDITIONAL"/>
      </CONDITIONAL>
    </item>
  </xsl:template>


  <xsl:template match="RESULT/ALL_STAGES/STAGES/BUSINESS_RULES/BUSINESS_RULE">
    <item>
      <IS_PASSED>
        <xsl:value-of select="IS_PASSED"/>
      </IS_PASSED>
      <IS_AGENT_PASSED>
        <xsl:value-of select="IS_AGENT_PASSED"/>
      </IS_AGENT_PASSED>
      <EXCEPTION_CLEARED>
        <xsl:value-of select="EXCEPTION_CLEARED"/>
      </EXCEPTION_CLEARED>
      <CLEAR_EXCEPTION>
        <xsl:value-of select="CLEAR_EXCEPTION"/>
      </CLEAR_EXCEPTION>
      <CLEARABLE_EXCEPTION>
        <xsl:value-of select="CLEARABLE_EXCEPTION"/>
      </CLEARABLE_EXCEPTION>
      <RULE_ID>
        <xsl:value-of select="RULE_ID"/>
      </RULE_ID>
      <ENABLED>
        <xsl:value-of select="ENABLED"/>
      </ENABLED>
      <TITLE>
        <xsl:value-of select="TITLE"/>
      </TITLE>
      <DESC>
        <xsl:value-of select="DESC"/>
      </DESC>
       <DATA_OBJ>
        <xsl:value-of select="DATA_OBJ"/>
      </DATA_OBJ>
       <TYPE>
        <xsl:value-of select="TYPE"/>
      </TYPE>
       <PRE_DFN_FN>
        <xsl:value-of select="PRE_DFN_FN"/>
      </PRE_DFN_FN>
       <AGENT>
        <xsl:value-of select="AGENT"/>
      </AGENT>
       <STAGE_NAME>
        <xsl:value-of select="STAGE_NAME"/>
      </STAGE_NAME>
    </item>
  </xsl:template>
  </xsl:transform>









